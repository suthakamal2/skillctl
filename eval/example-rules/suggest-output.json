{
  "we need to deploy v2 to staging tonight": {
    "bundles": [],
    "rules": [
      {
        "id": "safe-deploy",
        "tier": 2,
        "triggers": [
          "deploy",
          "staging"
        ]
      }
    ]
  },
  "the production database query is slow, what indexes should we add": {
    "bundles": [],
    "rules": [
      {
        "id": "safe-deploy",
        "tier": 2,
        "triggers": [
          "production"
        ]
      }
    ]
  },
  "set up authentication and authorization for the new API": {
    "bundles": [
      {
        "name": "backend-api",
        "overlap": 2
      }
    ],
    "rules": [
      {
        "id": "authentication",
        "tier": 2,
        "triggers": [
          "authentication"
        ]
      },
      {
        "id": "authorization",
        "tier": 2,
        "triggers": [
          "authorization"
        ]
      }
    ]
  },
  "we have a sev1 outage, walk me through incident response": {
    "bundles": [],
    "rules": [
      {
        "id": "incident-response",
        "tier": 2,
        "triggers": [
          "incident",
          "outage",
          "sev1"
        ]
      }
    ]
  },
  "add pagination and rate limiting to this endpoint": {
    "bundles": [],
    "rules": [
      {
        "id": "api-design",
        "tier": 2,
        "triggers": [
          "endpoint"
        ]
      },
      {
        "id": "pagination",
        "tier": 2,
        "triggers": [
          "pagination"
        ]
      }
    ]
  },
  "make this React component accessible": {
    "bundles": [],
    "rules": [
      {
        "id": "component-design",
        "tier": 2,
        "triggers": [
          "component",
          "react"
        ]
      }
    ]
  },
  "process these events asynchronously off a queue": {
    "bundles": [],
    "rules": [
      {
        "id": "queue-processing",
        "tier": 2,
        "triggers": [
          "queue"
        ]
      }
    ]
  },
  "rotate our API keys and audit dependencies for CVEs": {
    "bundles": [],
    "rules": [
      {
        "id": "dependency-audit",
        "tier": 2,
        "triggers": [
          "audit"
        ]
      }
    ]
  },
  "write a database migration that adds a nullable column": {
    "bundles": [],
    "rules": [
      {
        "id": "database-migrations",
        "tier": 2,
        "triggers": [
          "migration"
        ]
      }
    ]
  },
  "review this pull request before we merge": {
    "bundles": [
      {
        "name": "review-ready",
        "overlap": 2
      }
    ],
    "rules": [
      {
        "id": "git-workflow",
        "tier": 2,
        "triggers": [
          "merge",
          "pull request"
        ]
      },
      {
        "id": "code-review",
        "tier": 2,
        "triggers": [
          "review"
        ]
      }
    ]
  }
}